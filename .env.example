# Copy to .env and fill in. The .env file is git-ignored.

# ─── OpenAI (active default — gpt-5-mini) ───────────────────────────────────
# Set your key. MODEL below points every agent role at gpt-5-mini.
OPENAI_API_KEY=sk-your-key-here

# ─── Model selection (lives here, not in config.yaml) ───────────────────────
# MODEL sets the "provider:model" for EVERY agent role at once.
MODEL=openai:gpt-5-mini
# Per-role (each overrides MODEL for that role). All on gpt-5-mini here:
MODEL_DEFAULT=openai:gpt-5-mini
MODEL_DEFENDER=openai:gpt-5-mini
MODEL_ATTACKER=openai:gpt-5-mini
MODEL_JUDGE=openai:gpt-5-mini
MODEL_MATCHER=openai:gpt-5-mini
# Switch provider by changing the values (and setting matching credentials), e.g.:
# MODEL=ollama:qwen2.5:0.5b        # local, offline — see README "Local model (Ollama)"
# MODEL_ATTACKER=openai:gpt-4o     # point just the Attacker at a stronger model

# ─── Temperature (also here, not in config.yaml) ────────────────────────────
# Leave commented to NOT send the parameter — required by the gpt-5 line, which
# only accepts its default temperature. Uncomment only for models that allow it.
# TEMPERATURE sets every role; TEMPERATURE_<ROLE> overrides one role.
# TEMPERATURE=0.1
# TEMPERATURE_DEFENDER=0.5
# TEMPERATURE_ATTACKER=0.1
# TEMPERATURE_JUDGE=0.0

# ─── Google Vertex AI (alternative provider) ────────────────────────────────
# To use Vertex: set MODEL=google_vertexai:... above, then authenticate via
#   gcloud auth application-default login
#   gcloud auth application-default set-quota-project your-google-cloud-project-id
# and set the project/location below (ADC — no API key needed locally).
# Docker may need extra credential mounting (ADC file or service-account key).
# GOOGLE_CLOUD_PROJECT=your-google-cloud-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# ─── Local model (Ollama) ───────────────────────────────────────────────────
# Only used when MODEL points at an ollama: model. Defaults to localhost.
# Docker: the backend container reaches the host via host.docker.internal
# (already set in docker-compose.yml). Override here only for a remote/custom host.
# OLLAMA_BASE_URL=http://localhost:11434
