# Copy to .env and fill in. The .env file is git-ignored.

# ─── Google Vertex AI (default for local development) ───────────────────────
# For local development, authenticate via:
#   gcloud auth application-default login
#   gcloud auth application-default set-quota-project your-google-cloud-project-id
# This uses Application Default Credentials (ADC) — no API key needed locally.
GOOGLE_CLOUD_PROJECT=your-google-cloud-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Note: Docker deployment may require additional credential mounting (e.g.,
# mounting the ADC file or using a service account key). Not yet configured.

# ─── OpenAI (alternative provider) ──────────────────────────────────────────
# Uncomment and set if using OpenAI instead of Vertex AI:
# OPENAI_API_KEY=sk-your-key-here

# ─── Override model for all roles (single knob) ─────────────────────────────
# Leave unset to use the models defined in backend/config.yaml.
# MODEL=google_vertexai:gemini-2.5-flash
# MODEL=openai:gpt-4o
# MODEL=ollama:llama3.1            # local, offline — see README "Local model (Ollama)"

# ─── Local model (Ollama) ───────────────────────────────────────────────────
# Only used when MODEL/config points at an ollama: model. Defaults to localhost.
# Docker: the backend container reaches the host via host.docker.internal
# (already set in docker-compose.yml). Override here only for a remote/custom host.
# OLLAMA_BASE_URL=http://localhost:11434